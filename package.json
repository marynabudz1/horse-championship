    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.61.0",
